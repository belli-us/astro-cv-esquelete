---
import BaseLayout from "../layouts/BaseLayout.astro";
import Container from "../components/Container.astro";
import Footer from "../components/Footer.astro";
import Header from "../components/Header.astro";
import Nav from "../components/Nav.astro";
import { Icon } from "astro-icon/components";
import * as about from "./about/about.md";

const title = `${about.frontmatter.name} - ${about.frontmatter.designation}`;
const description = `Portfolio and CV of ${about.frontmatter.name}, ${about.frontmatter.designation} based in ${about.frontmatter.location}.`;
---

<BaseLayout title={title} description={description}>
  <a href="#main-content" class="sr-only focus:not-sr-only focus:absolute focus:top-2 focus:left-2 focus:z-50 btn btn-sm btn-primary">
    Skip to main content
  </a>

  <Header />

  <div
    class="flex items-center absolute top-4 right-4 md:top-6 md:right-6 lg:top-8 lg:right-8 xl:top-10 xl:right-10 z-10"
  >
    <Icon name="carbon:moon" class="w-4 h-4" aria-hidden="true" />
    <input
      type="checkbox"
      data-toggle-theme="black,lofi"
      data-act-class="ACTIVECLASS"
      class="toggle toggle-sm mx-1 bg-secondary"
      checked
      aria-label="Toggle dark and light theme"
    />
    <Icon name="carbon:light" class="w-4 h-4" aria-hidden="true" />
  </div>

  <div
    class="divider mx-auto h-fit max-w-3xl w-[95vw] flex flex-nowrap bg-secondary"
  >
  </div>

  <Nav />

  <main
    id="main-content"
    class="mx-auto flex-grow max-h-[90vh] md:max-h-[70vh] max-w-3xl overflow-y-scroll py-2 grid w-[95vw]"
  >
    <div class="container">
      <Container />
    </div>
  </main>

  <Footer class="flex justify-center items-center py-4" />
</BaseLayout>
